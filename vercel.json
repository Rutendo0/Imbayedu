{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/img/(.*)",
      "dest": "public/img/$1"
    },
    {
      "src": "/(.*)", 
      "dest": "/dist/public/index.html",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}